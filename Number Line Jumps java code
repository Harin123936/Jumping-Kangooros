import java.util.Scanner;

class Result {

    /**
     * Kangaroo function logic:
     * We use the relative velocity formula: (x2 - x1) % (v1 - v2) == 0
     */
    public static String kangaroo(int x1, int v1, int x2, int v2) {
        // Since x1 < x2, Kangaroo 1 must be faster than Kangaroo 2 to catch up.
        if (v1 > v2) {
            // Check if the distance gap is divisible by the speed difference.
            // This ensures they land on the same spot at the same jump number.
            if ((x2 - x1) % (v1 - v2) == 0) {
                return "YES";
            }
        }
        
        // If Kangaroo 1 is slower/same speed, or the jumps don't align perfectly.
        return "NO";
    }
}

public class Solution {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Read input: x1, v1, x2, v2
        if (scanner.hasNextInt()) {
            int x1 = scanner.nextInt();
            int v1 = scanner.nextInt();
            int x2 = scanner.nextInt();
            int v2 = scanner.nextInt();

            // Execute logic and print result
            String result = Result.kangaroo(x1, v1, x2, v2);
            System.out.println(result);
        }

        scanner.close();
    }
}
     
